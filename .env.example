# GitHub OAuth App credentials
# Create one at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth secret — any random string (e.g. run: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# GitHub Personal Access Token — used to fetch public profiles for /u/[username]
# Create one at: https://github.com/settings/tokens → Generate new token (classic)
# Required scopes: read:user, public_repo
GITHUB_TOKEN=
